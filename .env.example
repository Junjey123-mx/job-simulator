# ─── Base de datos PostgreSQL ────────────────────────────────────────────────
# Host del servicio de base de datos.
# En Docker: usar el nombre del servicio declarado en docker-compose.yml (db)
# En local:  usar localhost
DB_HOST=db

# Puerto estándar de PostgreSQL
DB_PORT=5432

# Nombre de la base de datos
DB_NAME=jobsimulator

# Usuario de la base de datos
DB_USER=postgres

# Contraseña del usuario (nunca subir el valor real al repositorio)
DB_PASSWORD=

# ─── Aplicación ──────────────────────────────────────────────────────────────
# Puerto en el que escucha el servidor Node.js
APP_PORT=8080
